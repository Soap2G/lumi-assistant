{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic (public default)",
      "env": ["ANTHROPIC_API_KEY"],
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (primary)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2025-09-01",
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (heaviest reasoning)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2025-11-01",
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": true,
          "release_date": "2025-10-01",
          "limit": { "context": 200000, "output": 8192 }
        }
      }
    },

    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CERN LiteLLM Gateway (CERN users only)",
      "env": ["LITELLM_API_KEY"],
      "options": {
        "baseURL": "https://llmgw-litellm.web.cern.ch/v1"
      },
      "models": {
        "gpt-4.1": {
          "name": "GPT-4.1 (flagship)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2025-06-01",
          "limit": { "context": 128000, "output": 8192 }
        },
        "mistral-large-latest": {
          "name": "Mistral Large 2 (flagship)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2024-11-01",
          "limit": { "context": 128000, "output": 8192 }
        },
        "mistral-medium-latest": {
          "name": "Mistral Medium 3 (balanced)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2025-05-01",
          "limit": { "context": 128000, "output": 8192 }
        },
        "mistral-small-latest": {
          "name": "Mistral Small (fast/cheap)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2025-03-01",
          "limit": { "context": 32768, "output": 8192 }
        },
        "codestral-latest": {
          "name": "Codestral (code generation)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2024-05-01",
          "limit": { "context": 32768, "output": 8192 }
        },
        "devstral-small-latest": {
          "name": "Devstral Small (Mistral coding)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2025-05-01",
          "limit": { "context": 131072, "output": 8192 }
        },
        "qwen/qwen3-32b": {
          "name": "Qwen 3 32B",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": false,
          "release_date": "2025-06-01",
          "limit": { "context": 32768, "output": 8192 }
        },
        "llama-3.1-8b-instruct": {
          "name": "Llama 3.1 8B (fast/lightweight)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2024-07-01",
          "limit": { "context": 8192, "output": 2048 }
        }
      }
    }
  },

  "model": "litellm/gpt-4.1",
  "small_model": "litellm/mistral-small-latest",

  "mcp": {
    "atlasopenmagic": {
      "type": "remote",
      "url": "https://atlasopenmagic-mcp.app.cern.ch/mcp",
      "oauth": false
    },
    "cernopendata": {
      "type": "remote",
      "url": "https://cernopendata-mcp.app.cern.ch/mcp",
      "oauth": false
    },
    "cerndocs": {
      "type": "remote",
      "url": "https://cern-mkdocs-mcp.app.cern.ch/mcp",
      "oauth": false
    },
    "rucio-atlas": {
      "type": "remote",
      "url": "https://rucio-mcp.app.cern.ch/site/atlas",
      "timeout": 30000
    },
    "rucio-cms": {
      "type": "remote",
      "url": "https://rucio-mcp.app.cern.ch/site/cms",
      "timeout": 30000
    },
    "rucio-escape": {
      "type": "remote",
      "url": "https://rucio-mcp.app.cern.ch/site/escape",
      "timeout": 30000
    },
    "rucio-fcc": {
      "type": "remote",
      "url": "https://rucio-mcp-fcc.app.cern.ch/site/fcc",
      "timeout": 30000
    }
  },

  "tools": {
    "rucio-*_rucio_add_rule": false,
    "rucio-*_rucio_delete_rule": false,
    "rucio-*_rucio_update_rule": false,
    "rucio-*_rucio_reduce_rule": false,
    "rucio-*_rucio_move_rule": false,
    "rucio-*_rucio_approve_rule": false,
    "rucio-*_rucio_deny_rule": false
  },

  "permission": {
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "ls *": "allow",
      "python *": "ask",
      "jupyter *": "ask",
      "pip *": "ask",
      "uv *": "ask",
      "curl *": "ask",
      "xrdcp *": "ask",
      "rucio whoami": "allow",
      "rucio ping": "allow",
      "rucio test-server": "allow",
      "rucio did list*": "allow",
      "rucio did show*": "allow",
      "rucio did content list*": "allow",
      "rucio did content history*": "allow",
      "rucio did metadata list*": "allow",
      "rucio replica list *": "allow",
      "rucio replica state list*": "allow",
      "rucio rse list*": "allow",
      "rucio rse show*": "allow",
      "rucio rse attribute list*": "allow",
      "rucio rse distance show*": "allow",
      "rucio rse qos list*": "allow",
      "rucio rule list*": "allow",
      "rucio rule show*": "allow",
      "rucio rule history*": "allow",
      "rucio account list*": "allow",
      "rucio account show*": "allow",
      "rucio account limit list*": "allow",
      "rucio account attribute list*": "allow",
      "rucio account identity list*": "allow",
      "rucio scope list*": "allow",
      "rucio subscription list*": "allow",
      "rucio download *": "ask",
      "rucio upload *": "ask",
      "rucio rule add*": "ask",
      "rucio rule move*": "ask",
      "rucio rule update*": "ask",
      "rucio did add*": "ask",
      "rucio did update*": "ask",
      "rucio did content add*": "ask",
      "rucio did metadata add*": "ask",
      "rucio replica state update*": "ask",
      "rucio rse add*": "ask",
      "rucio rse update*": "ask",
      "rucio rse attribute add*": "ask",
      "rucio account add*": "ask",
      "rucio account update*": "ask",
      "rucio scope add*": "ask",
      "rucio scope update*": "ask",
      "rucio rule remove*": "deny",
      "rucio did remove*": "deny",
      "rucio did content remove*": "deny",
      "rucio did metadata remove*": "deny",
      "rucio replica remove*": "deny",
      "rucio rse remove*": "deny",
      "rucio rse attribute remove*": "deny",
      "rucio account remove*": "deny",
      "rucio erase*": "deny",
      "rucio *": "ask",
      "voms-proxy-info*": "allow",
      "voms-proxy-init*": "ask",
      "reana-client ping": "allow",
      "reana-client version": "allow",
      "reana-client info": "allow",
      "reana-client list*": "allow",
      "reana-client status*": "allow",
      "reana-client logs*": "allow",
      "reana-client ls *": "allow",
      "reana-client du *": "allow",
      "reana-client quota-show*": "allow",
      "reana-client validate*": "allow",
      "reana-client diff*": "allow",
      "reana-client download*": "ask",
      "reana-client upload*": "ask",
      "reana-client create*": "ask",
      "reana-client start*": "ask",
      "reana-client open*": "ask",
      "reana-client close*": "ask",
      "reana-client mv*": "ask",
      "reana-client stop*": "deny",
      "reana-client delete*": "deny",
      "reana-client rm*": "deny",
      "reana-client prune*": "deny",
      "reana-client *": "ask",
      "fts-rest-whoami*": "allow",
      "fts-rest-server-status*": "allow",
      "fts-rest-transfer-list*": "allow",
      "fts-rest-transfer-status*": "allow",
      "fts-rest-transfer-submit*": "ask",
      "fts-rest-transfer-cancel*": "ask",
      "fts-rest-delete-submit*": "ask",
      "fts-rest-delegate*": "ask",
      "fts-rest-ban*": "deny",
      "fts-rest-* *": "ask",
      "rm *": "deny",
      "rm -rf*": "deny"
    },
    "edit": "allow",
    "webfetch": "allow"
  }
}
