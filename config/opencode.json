          "release_date": "2024-12-01",
          "limit": { "context": 128000, "output": 32768 }
        },
        "llama-3.1-8b-instant": {
          "name": "Llama 3.1 8B Instant (fast/lightweight)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": false,
          "release_date": "2024-07-01",
          "limit": { "context": 128000, "output": 8192 }
        },
        "qwen/qwen3.6-27b": {
          "name": "Qwen 3.6 27B",
          "tool_call": true,
