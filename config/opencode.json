        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2026-04-01",
          "limit": { "context": 1050000, "output": 128000 }
        },
        "gpt-5.3-chat-latest": {
          "name": "GPT-5.3 Chat (latest)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2026-03-01",
          "limit": { "context": 128000, "output": 16384 }
        },
        "gpt-5.2": {
          "name": "GPT-5.2",
          "tool_call": true,
