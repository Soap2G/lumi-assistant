{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic (public default)",
      "env": ["ANTHROPIC_API_KEY"],
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (primary)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2025-09-01",
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (heaviest reasoning)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2025-11-01",
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (fast/cheap)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": true,
          "release_date": "2025-10-01",
          "limit": { "context": 200000, "output": 8192 }
        }
      }
    },

    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CERN LiteLLM Gateway (CERN users only)",
      "env": ["LITELLM_API_KEY"],
      "options": {
        "baseURL": "https://llmgw-litellm.web.cern.ch/v1"
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol (newest flagship)",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2026-07-01",
          "limit": { "context": 1050000, "output": 128000 }
        },
        "gpt-5.6-terra": {
          "name": "GPT-5.6 Terra",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2026-07-01",
          "limit": { "context": 1050000, "output": 128000 }
        },
        "gpt-5.6-luna": {
          "name": "GPT-5.6 Luna",
          "tool_call": true,
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "release_date": "2026-07-01",
          "limit": { "context": 1050000, "output": 128000 }
