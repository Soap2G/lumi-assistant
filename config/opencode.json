          "limit": { "context": 272000, "output": 128000 }
        },
        "gpt-4.1": {
          "name": "GPT-4.1 (legacy flagship)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
          "attachment": true,
          "release_date": "2025-06-01",
          "limit": { "context": 1047576, "output": 32768 }
        },
        "gpt-4.1-nano": {
          "name": "GPT-4.1 Nano (fast/cheap)",
          "tool_call": true,
          "temperature": true,
          "reasoning": false,
